#include <stdio.h>
int main() {
    int l = 0, i, flag = 0;
    char str[100], rev[100];

    printf("Enter the string: ");
    scanf("%s", str);

    for (i = 0; str[i] != '\0'; i++)
    {
        l = l + 1;
    }
    for (i = 0;str[i] != '\0' ; i++)
    {
        rev[i] = str[l - i - 1];  
    }
    for (i = 0;str[i] != '\0' ; i++)
    {
        if (str[i] != rev[i]) {   
            flag = 1;
            break;
        }
    }

    if (flag == 1)
        printf("NOT A PALINDROME");
    else
        printf("PALINDROME");

    return 0;
}
